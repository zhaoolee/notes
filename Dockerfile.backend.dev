FROM mcr.microsoft.com/playwright:v1.58.2-noble

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci

ENV PORT=3001
ENV EXPORT_APP_URL=http://frontend:15173
ENV IMAGE_STORAGE_DIR=/app/storage/images

EXPOSE 3001

CMD ["sh", "scripts/dev-entrypoint.sh", "backend", "npm", "run", "backend:watch"]
